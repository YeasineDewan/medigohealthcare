# =============================================================================
# Medigo Healthcare - XAMPP Environment Configuration
# =============================================================================
# Copy this file to .env and configure for your environment
# Run: cp .env.xampp .env  &&  php artisan key:generate
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="Medigo Healthcare"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Dhaka

# -----------------------------------------------------------------------------
# Database (XAMPP Configuration)
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=medigo_db
DB_USERNAME=root
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Cache, Queue & Session
# -----------------------------------------------------------------------------
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# -----------------------------------------------------------------------------
# Redis (optional - disable for XAMPP)
# -----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Laravel Sanctum (API Auth)
# -----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173,127.0.0.1,127.0.0.1:8000,::1
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------
# Development: leave empty to use Vite proxy (/api -> backend)
# Production: set to your API base URL (e.g. https://api.your-domain.com/api/v1)
VITE_API_URL=

# -----------------------------------------------------------------------------
# Payment Gateway Configuration
# -----------------------------------------------------------------------------
PAYMENT_GATEWAY=bkash
PAYMENT_CURRENCY=BDT
PAYMENT_CURRENCY_SYMBOL=৳

# bKash Configuration
BKASH_ENABLED=true
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://checkout.sandbox.bka.sh/v1.2.0-beta

# Nagad Configuration
NAGAD_ENABLED=false
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=
NAGAD_PUBLIC_KEY=
NAGAD_PRIVATE_KEY=
NAGAD_BASE_URL=http://sandbox.mynagad.com:10080/remote-payment-gateway-1.0/api/dfs

# Rocket Configuration
ROCKET_ENABLED=false
ROCKET_MERCHANT_ID=
ROCKET_MERCHANT_PASSWORD=
ROCKET_BASE_URL=

# Stripe Configuration
STRIPE_ENABLED=false
STRIPE_KEY=
STRIPE_SECRET=

# -----------------------------------------------------------------------------
# Notification Settings
# -----------------------------------------------------------------------------
NOTIFICATION_MAIL_ENABLED=false
NOTIFICATION_SMS_ENABLED=false

# SMS Configuration
SMS_PROVIDER=twilio
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# -----------------------------------------------------------------------------
# Mail Configuration
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@medigo.com
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local

# AWS S3 Configuration (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------------------------------------
# Broadcasting (optional)
# -----------------------------------------------------------------------------
BROADCAST_DRIVER=log
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# -----------------------------------------------------------------------------
# Prescription Management System
# -----------------------------------------------------------------------------
PRESCRIPTION_STORAGE_PATH=prescriptions
PRESCRIPTION_MAX_FILE_SIZE=10485760
PRESCRIPTION_ALLOWED_TYPES=jpg,jpeg,png,webp
PRESCRIPTION_ENABLE_OCR=true
PRESCRIPTION_AUTO_VERIFY=false

# Prescription OCR Configuration
PRESCRIPTION_OCR_PROVIDER=tesseract
PRESCRIPTION_OCR_CONFIDENCE_THRESHOLD=0.7
PRESCRIPTION_OCR_LANGUAGE=eng

# Prescription Notification Settings
PRESCRIPTION_NOTIFY_UPLOAD=true
PRESCRIPTION_NOTIFY_VERIFY=true
PRESCRIPTION_NOTIFY_PROCESS=true
PRESCRIPTION_NOTIFY_COMPLETE=true

# -----------------------------------------------------------------------------
# API Keys and Authentication
# -----------------------------------------------------------------------------
API_KEY_ENABLED=true
API_KEY_EXPIRY_HOURS=8760
API_RATE_LIMIT=1000
API_RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESSION=true
BACKUP_ENCRYPTION=false

# -----------------------------------------------------------------------------
# Activity Logging
# -----------------------------------------------------------------------------
ACTIVITY_LOG_ENABLED=true
ACTIVITY_LOG_RETENTION_DAYS=90
ACTIVITY_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Role and Permission System
# -----------------------------------------------------------------------------
ROLES_ENABLED=true
PERMISSIONS_ENABLED=true
DEFAULT_ROLE=patient

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false
CSRF_PROTECTION=true
XSS_PROTECTION=true

# -----------------------------------------------------------------------------
# Performance Settings
# -----------------------------------------------------------------------------
CACHE_TTL=3600
QUERY_CACHE=true
ROUTE_CACHE=true
CONFIG_CACHE=true
