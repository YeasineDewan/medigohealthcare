# =============================================================================
# Medigo Healthcare - cPanel / Production Environment
# =============================================================================
# 1. Copy this file to .env on the server:  cp .env.cpanel.example .env
# 2. Fill in your domain, database credentials, and run: php artisan key:generate
# =============================================================================

# -----------------------------------------------------------------------------
# Application (PRODUCTION)
# -----------------------------------------------------------------------------
APP_NAME="Medigo Healthcare"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com
APP_TIMEZONE=Asia/Dhaka

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null

# -----------------------------------------------------------------------------
# Database (use cPanel MySQL credentials)
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_cpanel_db_name
DB_USERNAME=your_cpanel_db_user
DB_PASSWORD=your_cpanel_db_password

# -----------------------------------------------------------------------------
# Cache, Queue & Session
# -----------------------------------------------------------------------------
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

# -----------------------------------------------------------------------------
# Laravel Sanctum (use your live domain)
# -----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,www.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# -----------------------------------------------------------------------------
# Frontend (leave empty when frontend is served from same domain)
# -----------------------------------------------------------------------------
VITE_API_URL=

# -----------------------------------------------------------------------------
# Mail (optional - use cPanel Email or SMTP)
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mail.yourdomain.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local

# -----------------------------------------------------------------------------
# Security & Performance
# -----------------------------------------------------------------------------
API_KEY_ENABLED=true
CACHE_TTL=3600
ROUTE_CACHE=true
CONFIG_CACHE=true
