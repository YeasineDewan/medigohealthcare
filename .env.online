# =============================================================================
# Medigo Healthcare - Online Database Configuration
# =============================================================================
# Copy this file to .env and update with your online database details
# Run: cp .env.online .env
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="Medigo Healthcare"
APP_ENV=production
APP_KEY=base64:YourAppKeyHere
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=Asia/Dhaka

# -----------------------------------------------------------------------------
# Online Database Configuration
# =============================================================================
# UPDATE THESE WITH YOUR ONLINE DATABASE DETAILS
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=your-online-db-host.com
DB_PORT=3306
DB_DATABASE=medigo_db
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# -----------------------------------------------------------------------------
# Alternative Database Providers
# -----------------------------------------------------------------------------

# For AWS RDS
# DB_HOST=your-rds-instance.rds.amazonaws.com
# DB_USERNAME=your_rds_username
# DB_PASSWORD=your_rds_password

# For DigitalOcean Managed Database
# DB_HOST=your-do-db-host.do.db.ondigitalocean.com
# DB_PORT=25060
# DB_USERNAME=your_do_username
# DB_PASSWORD=your_do_password

# For PlanetScale
# DB_HOST=your-planetscale-host.planetscale.com
# DB_USERNAME=your_planetscale_username
# DB_PASSWORD=your_planetscale_password

# For Heroku Postgres (if using)
# DB_CONNECTION=pgsql
# DB_HOST=your-heroku-host.compute-1.amazonaws.com
# DB_PORT=5432
# DB_DATABASE=your_heroku_db
# DB_USERNAME=your_heroku_username
# DB_PASSWORD=your_heroku_password

# -----------------------------------------------------------------------------
# Mail Configuration
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=your-mail-host.com
MAIL_PORT=587
MAIL_USERNAME=your-email@domain.com
MAIL_PASSWORD=your-email-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@medigo.com
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local
# For cloud storage, uncomment and configure:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=your-s3-bucket
# AWS_ENDPOINT=https://s3.amazonaws.com

# -----------------------------------------------------------------------------
# Cache Configuration
# -----------------------------------------------------------------------------
CACHE_DRIVER=redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Session Configuration
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120

# -----------------------------------------------------------------------------
# Queue Configuration
# -----------------------------------------------------------------------------
QUEUE_CONNECTION=database

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_RATE_LIMIT=1000

# -----------------------------------------------------------------------------
# Prescription Management
# -----------------------------------------------------------------------------
PRESCRIPTION_MAX_FILE_SIZE=10485760
PRESCRIPTION_ALLOWED_TYPES=["jpg","jpeg","png","webp"]
PRESCRIPTION_ENABLE_OCR=true
PRESCRIPTION_AUTO_VERIFY=false

# -----------------------------------------------------------------------------
# Payment Configuration
# -----------------------------------------------------------------------------
PAYMENT_DEFAULT_CURRENCY=BDT
PAYMENT_DEFAULT_GATEWAY=bkash

# -----------------------------------------------------------------------------
# Notification Configuration
# -----------------------------------------------------------------------------
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=false

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=30
