Options -MultiViews -Indexes
RewriteEngine On
RewriteBase /

# Block direct access to source/internal directories in case of accidental upload.
RewriteRule ^(src|node_modules|server|app|bootstrap|config|database|resources|routes|storage|vendor)(/|$) - [R=404,L]

# Never rewrite static asset requests to index.html.
# If missing, return 404 instead of HTML (prevents "Unexpected token '<'").
RewriteRule \.(js|mjs|css|map|json|png|jpe?g|gif|webp|svg|ico|woff2?|ttf|eot|otf|mp4|webm|mp3|wav|ogg|pdf|xml|txt|webmanifest|avif|heic|heif)$ - [L]

# Serve existing files and directories directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Send everything else to index.html for React Router
RewriteRule ^ index.html [QSA,L]

# Correct MIME types for modern web assets
AddType application/javascript .js .mjs
AddType text/css .css
AddType image/svg+xml .svg
AddType image/avif .avif
AddType image/heic .heic
AddType image/heif .heif
AddType font/woff2 .woff2
AddType font/woff .woff
AddType font/ttf .ttf
AddType font/otf .otf
AddType application/manifest+json .webmanifest
AddType application/json .json
AddType application/pdf .pdf
AddType video/mp4 .mp4
AddType video/webm .webm
AddType audio/mpeg .mp3
AddType audio/wav .wav
AddType audio/ogg .ogg

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Cross-Origin-Resource-Policy "same-origin"
    Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
    Header always set Cross-Origin-Embedder-Policy "unsafe-none"
</IfModule>

# Long-term cache baseline
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/heic "access plus 1 year"
    ExpiresByType image/heif "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType video/mp4 "access plus 1 year"
    ExpiresByType video/webm "access plus 1 year"
    ExpiresByType audio/mpeg "access plus 1 year"
    ExpiresByType audio/wav "access plus 1 year"
    ExpiresByType audio/ogg "access plus 1 year"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType application/json "access plus 1 hour"
    ExpiresByType application/manifest+json "access plus 1 day"
    # No cache for index.html — always fresh
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Immutable caching for hashed build files
<IfModule mod_headers.c>
    <FilesMatch "\.[0-9A-Za-z_-]{8,}\.(?:js|mjs|css|png|jpe?g|gif|webp|svg|avif|woff2?|ttf|otf|mp4|webm)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "^(index\.html|sw\.js|service-worker\.js)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# Compression (Brotli first, fallback gzip)
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml application/manifest+json
</IfModule>
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml application/manifest+json
</IfModule>

# Reduce weak validator collisions after frequent deploys
FileETag None
